{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "bench_synthetic (interactive — F5 default)",
            "type": "debugpy",
            "request": "launch",
            "module": "scripts.bench_synthetic",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "args": [
                "--interactive"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "bench_synthetic (profile: s_quick — full sweep)",
            "type": "debugpy",
            "request": "launch",
            "module": "scripts.bench_synthetic",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "args": [
                "--profile",
                "s_quick"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "bench_synthetic (profile: s_smoke — fast)",
            "type": "debugpy",
            "request": "launch",
            "module": "scripts.bench_synthetic",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "args": [
                "--profile",
                "s_smoke"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "bench_synthetic (profile: m_medium — large run)",
            "type": "debugpy",
            "request": "launch",
            "module": "scripts.bench_synthetic",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "args": [
                "--profile",
                "m_medium"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "bench_real (auto-find wav, all models)",
            "type": "debugpy",
            "request": "launch",
            "module": "scripts.bench_real",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "args": [
                "--n-repeats",
                "3",
                "--models",
                "all"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "bench_real (prompt for --wav)",
            "type": "debugpy",
            "request": "launch",
            "module": "scripts.bench_real",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "args": [
                "--wav",
                "${input:wavPath}",
                "--models",
                "all"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        }
    ],
    "inputs": [
        {
            "id": "wavPath",
            "type": "promptString",
            "description": "Path to .wav file for bench_real",
            "default": "test/sample.wav"
        }
    ]
}
